# ── SpeakScorer Environment Configuration ─────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── JWT ───────────────────────────────────────────────────
# MUST be a strong, random secret. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=CHANGE_ME_TO_RANDOM_SECRET
JWT_EXPIRE_MINUTES=1440

# ── Google APIs ───────────────────────────────────────────
# Leave empty to enable DEMO_MODE (mock AI evaluations)
GEMINI_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=

# ── Database ──────────────────────────────────────────────
DATABASE_URL=sqlite:///./speakai.db

# ── CORS ──────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ── Seeding ───────────────────────────────────────────────
# Set to "true" to seed demo data on startup (first run only)
SEED_ENABLED=false
SEED_ADMIN_PASSWORD=
SEED_TEACHER_PASSWORD=
SEED_STUDENT_PASSWORD=
SEED_PARENT_PASSWORD=

# ── Demo Mode ─────────────────────────────────────────────
# Set to "true" to force demo mode (mock AI, no real API calls)
# If empty, auto-detected from GEMINI_API_KEY presence
DEMO_MODE=

# ── Environment ───────────────────────────────────────────
# "production" enables hardened defaults: Secure cookies, no /docs, HSTS.
ENVIRONMENT=development

# ── Auth cookies (JWT is delivered as an HttpOnly cookie) ──
# COOKIE_SECURE: HTTPS gerektirir. Üretimde otomatik açık; yerel HTTP için "false".
COOKIE_SECURE=
COOKIE_SAMESITE=strict
# COOKIE_DOMAIN=          # (opsiyonel) örn: .speakscorer.com

# ── Rate limiting / brute-force (in-memory, tek süreç) ────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_GLOBAL_MAX=300
RATE_LIMIT_GLOBAL_WINDOW=60
RATE_LIMIT_AUTH_MAX=8
RATE_LIMIT_AUTH_WINDOW=60
LOGIN_MAX_FAILURES=5
LOGIN_LOCKOUT_SECONDS=900

# ── CAPTCHA (Cloudflare Turnstile) ────────────────────────
# https://dash.cloudflare.com -> Turnstile -> Add site (ücretsiz)
# Secret boşsa CAPTCHA otomatik DEVRE DIŞI kalır (yerel geliştirme için).
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# CAPTCHA_ENABLED=        # (opsiyonel) "true"/"false" ile zorla

# ── Password policy ───────────────────────────────────────
PASSWORD_MIN_LENGTH=8
