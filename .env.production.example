# ═══════════════════════════════════════════════════════════
# SpeakAI — ÜRETİM ortam şablonu (Oracle Cloud Always Free)
#
# KULLANIM (VM üzerinde):
#   cp .env.production.example .env.production
#   nano .env.production          # aşağıdaki DEĞİŞTİR alanlarını doldur
#   docker compose --env-file .env.production up -d --build
#
# ⚠ .env.production GERÇEK SIRLARI içerir ve .gitignore ile dışlanmıştır.
#   ASLA commit'leme, ASLA paylaşma.
# ═══════════════════════════════════════════════════════════

# ── Alan adı & HTTPS (Caddy için ZORUNLU) ─────────────────
# DuckDNS vb. ile aldığın alan adı. VM'in public IP'sine A kaydı ile
# işaret etmeli. Let's Encrypt sertifikası bunun üzerinden alınır.
DOMAIN=senin-app.duckdns.org
# Let's Encrypt sertifika bildirimleri için geçerli bir e-posta.
ACME_EMAIL=seninmail@example.com

# ── JWT (ZORUNLU — YENİ üret, eskisi ifşa kabul ediliyor) ──
# Üret:  python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=DEĞİŞTİR_GUCLU_RASTGELE_64_KARAKTER
JWT_EXPIRE_MINUTES=1440

# ── Google Gemini (ZORUNLU — eski anahtarı İPTAL et, YENİ al) ──
GEMINI_API_KEY=DEĞİŞTİR_YENI_GEMINI_ANAHTARI
GOOGLE_APPLICATION_CREDENTIALS=

# ── CORS (ZORUNLU — kendi alan adın, https ile) ───────────
CORS_ORIGINS=https://senin-app.duckdns.org

# ── Ortam ─────────────────────────────────────────────────
# compose zaten production'a sabitliyor; yine de açıkça belirtelim.
ENVIRONMENT=production

# ── DATABASE_URL ──────────────────────────────────────────
# Buraya YAZMA. docker-compose.yml bunu kalıcı volume'a
# (sqlite:////app/data/speakai.db) zaten yönlendiriyor.

# ── CAPTCHA (Cloudflare Turnstile — üretimde ZORUNLU) ─────
# https://dash.cloudflare.com -> Turnstile -> Add site (ücretsiz)
# Boş bırakırsan uygulama açılışta FATAL verir (CAPTCHA_REQUIRED=production).
# Bilinçli kapatmak istersen CAPTCHA_REQUIRED=false ekle (ÖNERİLMEZ).
TURNSTILE_SITE_KEY=DEĞİŞTİR_TURNSTILE_SITE_KEY
TURNSTILE_SECRET_KEY=DEĞİŞTİR_TURNSTILE_SECRET_KEY
# CAPTCHA_REQUIRED=false

# ── Çekirdek veri tohumlama (SADECE ilk kurulumda) ────────
# İlk açılışta admin/öğretmen/öğrenci hesaplarını oluşturmak istersen:
#   1) SEED_ENABLED=true yap ve aşağıdaki şifreleri GÜÇLÜ değerlerle doldur
#   2) Konteyneri bir kez çalıştır, hesaplar oluşsun
#   3) SEED_ENABLED=false yapıp tekrar `up -d` ile yeniden başlat
# Üretimde kalıcı olarak false kalmalı.
SEED_ENABLED=false
SEED_ADMIN_PASSWORD=
SEED_TEACHER_PASSWORD=
SEED_STUDENT_PASSWORD=
SEED_PARENT_PASSWORD=

# ── Cookie / parola politikası ────────────────────────────
COOKIE_SAMESITE=strict
PASSWORD_MIN_LENGTH=8

# ── Rate limiting (varsayılanlar genelde yeterli) ─────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_GLOBAL_MAX=300
RATE_LIMIT_GLOBAL_WINDOW=60
RATE_LIMIT_AUTH_MAX=8
RATE_LIMIT_AUTH_WINDOW=60
LOGIN_MAX_FAILURES=5
LOGIN_LOCKOUT_SECONDS=900
